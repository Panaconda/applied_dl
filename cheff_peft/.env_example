# Dataset paths for VinDr-PCXR experiments.
# Copy this file to .env and set all four paths.
# These are REQUIRED — there are no defaults.
# Paths are relative to the cheff_peft/ directory (where scripts are run from).

# MaCheX-processed VinDr-PCXR dataset (1024×1024 JPG, sequential filenames)
TRAIN_IMAGE_DIR=../data/machex_dataset/vindr-pcxr/train/00
TEST_IMAGE_DIR=../data/machex_dataset/vindr-pcxr/test/00
TRAIN_LABELS_CSV=../data/machex_dataset/vindrcxr/vindr-pcxr/train/00
TEST_LABELS_CSV=../data/machex_dataset/vindrcxr/vindr-pcxr/test/00
TRAIN_ANNOTATIONS_CSV=../data/machex_dataset/vindrcxr/vindr-pcxr/train/00


# MaCheX index files — map sequential filenames back to image_ids
VINDR_PCXR_TRAIN_INDEX=../data/machex_dataset/vindr-pcxr/train/index.json
VINDR_PCXR_TEST_INDEX=../data/machex_dataset/vindr-pcxr/test/index.json

MACHEX_OUTPUT_DIR=../data/machex_dataset/vindr-pcxr/train/

# Pre-trained CheFF checkpoints (for fine-tuning)
CHEFF_T2I_CKPT=pretrained_models/cheff_t2i_ckpt.pt
CHEFF_AE_CKPT=pretrained_models/cheff_ae_ckpt.pt