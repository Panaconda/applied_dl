# Dataset paths for VinDr-PCXR experiments.
# Copy this file to .env and set all four paths.
# These are REQUIRED — there are no defaults.
# Paths are relative to the experiments/ directory (where scripts are run from).

TRAIN_IMAGE_DIR=../data/vindr-pcxr-mini/Pre-256/Train
TEST_IMAGE_DIR=../data/vindr-pcxr-mini/Pre-256/Test
TRAIN_LABELS_CSV=../data/physionet.org/files/vindr-pcxr/1.0.0/image_labels_train.csv
TEST_LABELS_CSV=../data/physionet.org/files/vindr-pcxr/1.0.0/image_labels_test.csv

# Optional CoreConfig overrides:
# IMAGE_SIZE=224
# RUNS_DIR=./runs

# Optional BaselineConfig overrides:
# RUN_NAME=baseline
# BATCH_SIZE=32
# NUM_WORKERS=4
# MAX_EPOCHS=50
# WARMUP_EPOCHS=3
# LR_HEAD=0.0001
# LR_BACKBONE=0.00001
# PATIENCE=5
# MONITOR_METRIC=val/auroc
# ACCELERATOR=auto
# DEVICES=auto
# PRECISION=16-mixed
