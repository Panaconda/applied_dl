# Dataset paths for VinDr-PCXR experiments.
# Copy this file to .env and set all four paths.
# These are REQUIRED — there are no defaults.
# Paths are relative to the experiments/ directory (where scripts are run from).

# MaCheX-processed VinDr-PCXR dataset (1024×1024 JPG, sequential filenames)
TRAIN_IMAGE_DIR=../data/vindr-pcxr/Train
TEST_IMAGE_DIR=../data/vindr-pcxr/Test
TRAIN_LABELS_CSV=../data/vindr-pcxr/image_labels_train.csv
TEST_LABELS_CSV=../data/vindr-pcxr/image_labels_test.csv

# MaCheX index files — map sequential filenames back to image_ids
VINDR_PCXR_TRAIN_INDEX=../data/vindr-pcxr/index.json
VINDR_PCXR_TEST_INDEX=../data/vindr-pcxr/index_test.json

# Optional CoreConfig overrides:
# IMAGE_SIZE=224
# RUNS_DIR=./runs

# Optional BaselineConfig overrides:
# RUN_NAME=baseline
# BATCH_SIZE=32
# NUM_WORKERS=4
# MAX_EPOCHS=50
# WARMUP_EPOCHS=3
# LR_HEAD=0.0001
# LR_BACKBONE=0.00001
# PATIENCE=5
# MONITOR_METRIC=val/auroc
# ACCELERATOR=auto
# DEVICES=auto
# PRECISION=16-mixed
