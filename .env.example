# ── applied_dl environment configuration ──────────────────────────────
# Copy to .env and fill in values specific to your machine.
#   cp .env.example .env
#
# All values below are read by pydantic-settings configs in:
#   cheff_peft/finetune_cheff/config.py   (FinetuneCheffConfig)
#   classifier/core/config.py             (CoreConfig)
#   classifier/baseline/config.py         (BaselineConfig)
#
# IMPORTANT: All path variables (CHECKPOINT_DIR, DATA_DIR, MACHEX_OUTPUT_DIR, etc.)
# have sensible absolute defaults derived from the project root inside each config.
# DO NOT add path overrides here unless you are storing data outside the project tree.
# Broken or relative path overrides in .env will shadow the correct defaults.
#
# NOTE: taming-transformers requires PYTHONPATH in your shell (not here).
# setup_cloud_gpu.sh adds this automatically, or run manually:
#   echo 'export PYTHONPATH=/absolute/path/to/src/taming-transformers' >> ~/.bashrc

# Hardware accelerator: "gpu", "cpu", or "auto"
ACCELERATOR=gpu

# ── LRZ cluster (used by 03_migrate_to_cluster.sh) ────────────────────
LRZ_USER=ra68jip2
LRZ_HOST=login.ai.lrz.de
LRZ_SCRATCH=/dss/mcmlscratch/04/ra68jip2
