# ── applied_dl environment configuration ──────────────────────────────
# Copy to .env and adjust paths for your machine / cluster.
#   cp .env.example .env
#
# All values below are read by pydantic-settings configs in:
#   cheff_peft/finetune_cheff/config.py   (FinetuneCheffConfig)
#   classifier/core/config.py             (CoreConfig)
#   classifier/baseline/config.py         (BaselineConfig)
#
# NOTE: taming-transformers requires PYTHONPATH to be set in your shell, not here.
# Add to ~/.bashrc: export PYTHONPATH=/absolute/path/to/src/taming-transformers

# ── CheFF fine-tuning ─────────────────────────────────────────────────
# Directory containing the pretrained CheFF checkpoints
# Use absolute paths to avoid issues with working directory.
CHECKPOINT_DIR=~/applied_dl/cheff_peft/checkpoints

# Full paths to individual checkpoint files
CHEFF_T2I_CKPT=~/applied_dl/cheff_peft/checkpoints/cheff_diff_t2i.pt
CHEFF_AE_CKPT=~/applied_dl/cheff_peft/checkpoints/cheff_autoencoder.pt

# MaCheX-formatted dataset used to train the diffusion model
# Use absolute path to avoid issues with working directory (script runs from cheff_peft/)
MACHEX_OUTPUT_DIR=/home/ubuntu/adl/applied_dl/machex_dataset/vindr-pcxr

# ── Classifier / shared data paths ───────────────────────────────────
DATA_DIR=./data/pcxr_png

# Hardware accelerator: "gpu", "cpu", or "auto"
ACCELERATOR=gpu
