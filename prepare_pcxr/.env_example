# VinDr-PCXR Download & Processing Configuration
# Paths are relative to the prepare_pcxr/ directory

# Data storage paths
PCXR_PNG_ROOT=../data/pcxr_png/
PCXR_DICOM_ROOT=../data/pcxr_dicom/

# Processing settings
NUM_WORKERS=4
FRONTAL_ONLY=True

# PhysioNet Credentials (REQUIRED for download_pcxr.py)
# Sign up at https://physionet.org/ to access the VinDr-PCXR dataset
PHYSIO_USERNAME=your_username_here
PHYSIO_PASSWORD=your_password_here
